HOSTEUROPE_FTP_HOST=
HOSTEUROPE_FTP_USER=
HOSTEUROPE_FTP_PASS=
# Remote FTP path (default: /)
# HOSTEUROPE_FTP_PATH=/

# Base path for deployment (e.g. /notestr for subdirectory, empty for root)
# NEXT_PUBLIC_BASE_PATH=/notestr

# Relay configuration (optional — overrides built-in defaults)
# Dev default: ws://localhost:7777
# Prod default: wss://nos.lol,wss://relay.primal.net,wss://purplepag.es,wss://offchain.pub
# NEXT_PUBLIC_RELAYS=wss://nos.lol,wss://relay.primal.net
# NEXT_PUBLIC_NOSTRCONNECT_RELAY=wss://relay.primal.net
