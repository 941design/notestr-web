{
  "name": "notestr",
  "version": "0.1.0",
  "type": "module",
  "description": "Encrypted task manager on Nostr with MLS groups",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "test": "npm run test:unit && npm run test:export",
    "test:unit": "vitest run",
    "test:export": "node ./scripts/verify-static-export.mjs",
    "relay:up": "docker compose up -d",
    "relay:down": "docker compose down"
  },
  "keywords": [
    "nostr",
    "mls",
    "marmot",
    "task-manager"
  ],
  "license": "MIT",
  "dependencies": {
    "@hpke/chacha20poly1305": "^1.7.1",
    "@internet-privacy/marmot-ts": "github:941design/marmot-ts#addressable-key-packages",
    "@nostr-dev-kit/ndk": "^3.0.3",
    "@tailwindcss/postcss": "^4.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^0.577.0",
    "next": "^15.3.4",
    "next-themes": "^0.4.6",
    "nostr-tools": "^2.23.3",
    "qr-scanner": "^1.4.2",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "fast-check": "^3.23.0",
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "serve": "^14.2.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
